# -*- coding: utf-8 -*-
import RPi.GPIO as GPIO
import time

GPIO.setmode(GPIO.BOARD)
GPIO.setwarnings(False)

# --- MOTOR PINS ---
IN1, IN2, ENA = 13, 15, 11
IN3, IN4, ENB = 16, 18, 12

GPIO.setup([IN1, IN2, ENA, IN3, IN4, ENB], GPIO.OUT)

# --- PWM SETUP ---
pwm_left = GPIO.PWM(ENA, 100)
pwm_right = GPIO.PWM(ENB, 100)
pwm_left.start(0)
pwm_right.start(0)

# --- PID PARAMETERS ---
KP, KI, KD = 1.2, 0.0, 0.2
prev_error, integral = 0, 0
last_time = time.time()

# --- LINEAR REGRESSION CONSTANTS ---
# Updated based on experimental average distance over 3 seconds
M_SLOPE = 62.40
C_INTERCEPT = 16.54
MAX_PWM_LIMIT = 50 

def speed_to_pwm(target_m_s):
    pwm = (M_SLOPE * target_m_s) + C_INTERCEPT
    return max(0, min(MAX_PWM_LIMIT, pwm))

def pid_control(error):
    global prev_error, integral, last_time
    now = time.time()
    dt = now - last_time
    last_time = now
    integral += error * dt
    derivative = (error - prev_error) / dt if dt > 0 else 0
    prev_error = error
    return (KP * error) + (KI * integral) + (KD * derivative)

def set_motor_speed(left, right):
    left = max(0, min(MAX_PWM_LIMIT, left))
    right = max(0, min(MAX_PWM_LIMIT, right))
    pwm_left.ChangeDutyCycle(left)
    pwm_right.ChangeDutyCycle(right)

def stop():
    GPIO.output([IN1, IN2, IN3, IN4], False)
    set_motor_speed(0, 0)

def move_forward_pid(base_pwm, error):
    correction = pid_control(error)
    set_motor_speed(base_pwm - correction, base_pwm + correction)
    GPIO.output(IN1, True)
    GPIO.output(IN2, False)
    GPIO.output(IN3, False)
    GPIO.output(IN4, True)

# --- MAIN PROGRAM ---
try:
    print("\n--- ROBOT CONTROL MODE ---")
    print(f"Max Speed Allowed: 0.53 m/s (PWM {MAX_PWM_LIMIT}%)")
    
    target_speed = float(input("Enter target speed in m/s: "))
    duration = float(input("Enter duration (seconds): "))

    base_pwm = speed_to_pwm(target_speed)
    
    # We still need a placeholder error if you aren't using encoders 
    # to keep the motors perfectly synced. If encoders are disconnected, 
    # 'error' will remain 0.
    error = 0 
    
    print(f"Moving at {target_speed} m/s for {duration}s...")
    
    start_time = time.time()
    while time.time() - start_time < duration:
        # If you have encoders, you can still use them for PID error 
        # without using them for the distance math.
        move_forward_pid(base_pwm, error)
        time.sleep(0.02)

    stop()
    
    # --- CALCULATE DISTANCE (SPEED * TIME) ---
    # This uses your physical speed input and the actual time elapsed
    end_time = time.time()
    actual_duration = end_time - start_time
    calculated_distance = target_speed * actual_duration

    print("\n" + "="*30)
    print("      RUN COMPLETED")
    print("="*30)
    print(f"Target Speed:   {target_speed} m/s")
    print(f"Actual Time:    {actual_duration:.2f} s")
    print(f"Total Distance: {calculated_distance:.2f} meters")
    print("="*30)

except KeyboardInterrupt:
    print("\nEmergency Stop")
finally:
    stop()
    pwm_left.stop()
    pwm_right.stop()
    GPIO.cleanup()
